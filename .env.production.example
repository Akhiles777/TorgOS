# Скопируйте в .env рядом с docker-compose.yml и задайте секреты.
#   cp .env.production.example .env
# ВНИМАНИЕ: .env не коммитить.

# --- База данных ---
POSTGRES_USER=torgos
# Сильный пароль (обязательно смените!):
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=redstore

# --- Приложение ---
# Секрет для подписи/хеша сессий. Сгенерировать: openssl rand -base64 48
AUTH_SECRET=CHANGE_ME_openssl_rand_base64_48
# Внешний порт, на котором будет доступно приложение (за ним ставьте nginx+TLS)
APP_PORT=3000

# --- Бэкапы ---
BACKUP_INTERVAL=86400   # период бэкапа, сек (86400 = раз в сутки)
BACKUP_KEEP=14          # сколько последних копий хранить

# --- ИИ-сводка владельца (routerai.ru) ---
# Необязательно: без ключа секция «Сводка от ИИ» просто не показывается,
# честные рекомендации-правила работают независимо от неё.
ROUTERAI_API_KEY=
ROUTERAI_MODEL=anthropic/claude-sonnet-5
