generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgType {
  RETAIL
  HORECA
}

enum Plan {
  TRIAL
  BASIC
  PRO
}

enum Role {
  OWNER
  ADMIN
  CASHIER
}

enum Unit {
  PCS
  KG
}

enum MovementType {
  IN
  OUT
  WRITEOFF
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

model Organization {
  id         String      @id @default(cuid())
  name       String
  type       OrgType
  plan       Plan        @default(TRIAL)
  createdAt  DateTime    @default(now())
  stores     Store[]
  users      User[]
  aiBriefing AiBriefing?
}

model Store {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  address        String
  users          User[]
  products       Product[]
  sales          Sale[]
  suppliers      Supplier[]
  employees      Employee[]
  shifts         Shift[]

  @@index([organizationId])
}

// Сотрудник смены — тот, кто физически стоит на кассе (Земфира, Рита…).
// НЕ логин-аккаунт: касса работает под одной учёткой, а «кто на смене»
// выбирается одним тапом. Продажи атрибутируются на этого сотрудника.
model Employee {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  shifts    Shift[]
  sales     Sale[]

  @@index([storeId])
}

// Смена — кто выбран «за управлением» в конкретный кассовый день.
// Кассовый день считается по границе 07:00 МСК (shiftDay = "YYYY-MM-DD").
model Shift {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftDay   String
  createdAt  DateTime @default(now())

  @@index([storeId, shiftDay])
}

model User {
  id             String          @id @default(cuid())
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storeId        String?
  store          Store?          @relation(fields: [storeId], references: [id])
  role           Role
  name           String
  login          String          @unique
  passwordHash   String
  createdAt      DateTime        @default(now())
  sessions       Session[]
  sales          Sale[]
  movements      StockMovement[]

  @@index([organizationId])
}

// id — sha256-хэш токена; сам токен живёт только в cookie
model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}

model Product {
  id        String          @id @default(cuid())
  storeId   String
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  barcode   String?
  name      String
  price     Decimal         @db.Decimal(10, 2)
  costPrice Decimal         @db.Decimal(10, 2)
  unit      Unit            @default(PCS)
  category  String
  expiry    DateTime?
  stock     Decimal         @default(0) @db.Decimal(10, 3)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  movements StockMovement[]
  saleItems SaleItem[]

  @@unique([storeId, barcode])
  @@index([storeId, category])
}

model StockMovement {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      MovementType
  quantity  Decimal      @db.Decimal(10, 3)
  reason    String?
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())

  @@index([productId, createdAt])
}

model Sale {
  id            String        @id @default(cuid())
  number        Int           @default(autoincrement())
  storeId       String
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashierId     String
  cashier       User          @relation(fields: [cashierId], references: [id])
  // Сотрудник смены, на которого записана продажа (кто был «за управлением»).
  // Nullable: старые чеки и продажи без выбранной смены.
  employeeId    String?
  employee      Employee?     @relation(fields: [employeeId], references: [id])
  total         Decimal       @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  cashGiven     Decimal?      @db.Decimal(10, 2)
  changeGiven   Decimal?      @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())
  items         SaleItem[]

  @@index([storeId, createdAt])
  @@index([employeeId])
}

model SaleItem {
  id          String  @id @default(cuid())
  saleId      String
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Decimal @db.Decimal(10, 3)
  priceAtSale Decimal @db.Decimal(10, 2)

  @@index([productId])
}

// Кеш ИИ-сводки владельца: одна запись на организацию (кабинет владельца
// агрегирует ВСЕ точки организации, поэтому ключ — organizationId, не storeId),
// перегенерируется по TTL. Разделено с рекомендациями-правилами (Insight) —
// эта сводка неточная/сгенерированная, правила остаются источником истины
// и работают даже если ИИ недоступен.
model AiBriefing {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  content        String
  model          String
  generatedAt    DateTime     @default(now())
}

model Supplier {
  id      String  @id @default(cuid())
  storeId String
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name    String
  phone   String?
  notes   String?

  @@index([storeId])
}
